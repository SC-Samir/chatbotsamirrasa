# Scalingo API token (required)
SCALINGO_API_TOKEN=replace_with_your_scalingo_api_token

# Redis URL
REDIS_URL=redis://localhost:6379/0
MEMORY_SESSION_TTL_SECONDS=3600
DATABASE_URL=postgresql://user:pass@localhost:5432/scalingoops
# Optional override if memory uses dedicated DB
MEMORY_POSTGRES_DSN=

# Rasa service URL
RASA_URL=http://localhost:5005
RASA_TIMEOUT_MS=3000
RASA_AUTH_TOKEN=
NLU_EXPECTED_CONTRACT=v3

# App settings
DEBUG=false
APP_NAME=ScalingoOps Agent
WEB_CONCURRENCY=2
CELERY_CONCURRENCY=1
