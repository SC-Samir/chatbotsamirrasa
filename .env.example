# ==============================
# ScalingoOps Agent environment
# ==============================

# REQUIRED: your Scalingo API token
SCALINGO_API_TOKEN=replace_with_your_scalingo_api_token

# Redis URL for local run (outside Docker)
# In Docker Compose, redis://redis:6379/0 is already injected.
REDIS_URL=redis://localhost:6379/0

# Rasa model path used by the app
RASA_MODEL_PATH=models/model.tar.gz

# App debug mode
DEBUG=false

# Optional app metadata
APP_NAME=ScalingoOps Agent
